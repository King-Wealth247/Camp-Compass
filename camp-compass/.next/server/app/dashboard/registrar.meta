{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/registrar/layout,_N_T_/dashboard/registrar/page,_N_T_/dashboard/registrar"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/registrar/__PAGE__",
    "/dashboard/registrar",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}