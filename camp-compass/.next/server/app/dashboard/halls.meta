{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/halls/layout,_N_T_/dashboard/halls/page,_N_T_/dashboard/halls"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/halls/__PAGE__",
    "/dashboard/halls",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}